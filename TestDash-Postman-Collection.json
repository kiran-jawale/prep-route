{
  "info": {
    "name": "TestDash API - Complete",
    "description": "Complete API collection for TestDash with Auth, Subjects, Topics, SubTopics, Tests, and Questions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"vedant-admin\",\n  \"fullName\": \"Vedant Admin\",\n  \"email\": \"vedant@example.com\",\n  \"password\": \"vedant123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"vedant-admin\",\n  \"password\": \"vedant123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh-token",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh-token"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Subjects",
      "item": [
        {
          "name": "Get All Subjects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/subjects",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "subjects"]
            }
          }
        }
      ]
    },
    {
      "name": "Topics",
      "item": [
        {
          "name": "Get Topics By Subject",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/topics/subject/{{subject_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "topics", "subject", "{{subject_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "SubTopics",
      "item": [
        {
          "name": "Get SubTopics By Topic",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/sub-topics/topic/{{topic_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "sub-topics", "topic", "{{topic_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Tests",
      "item": [
        {
          "name": "Get All Tests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tests",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tests"]
            }
          }
        },
        {
          "name": "Get Test By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tests/{{test_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tests", "{{test_id}}"]
            }
          }
        },
        {
          "name": "Create Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Algebra Practice Test\",\n  \"category\": \"chapterWise\",\n  \"subjectId\": \"{{subject_id}}\",\n  \"topics\": [\n    \"{{topic_id}}\"\n  ],\n  \"subTopics\": [\n    \"{{subtopic_id}}\"\n  ],\n  \"difficulty\": \"medium\",\n  \"correctMarks\": 4,\n  \"wrongMarks\": -1,\n  \"unattemptMarks\": 0,\n  \"totalTime\": 60,\n  \"totalMarks\": 200,\n  \"totalQuestions\": 50,\n  \"publishMode\": \"now\",\n  \"availableUntil\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tests",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tests"]
            }
          }
        },
        {
          "name": "Update Test",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Test Name\",\n  \"difficulty\": \"difficult\",\n  \"totalQuestions\": 25,\n  \"totalMarks\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tests/{{test_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tests", "{{test_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "Bulk Create Questions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questions\": [\n    {\n      \"testId\": \"{{test_id}}\",\n      \"subjectId\": \"{{subject_id}}\",\n      \"topicId\": \"{{topic_id}}\",\n      \"subTopicId\": \"{{subtopic_id}}\",\n      \"type\": \"mcq\",\n      \"question\": \"What is 2 + 2 ?\",\n      \"option1\": \"1\",\n      \"option2\": \"2\",\n      \"option3\": \"3\",\n      \"option4\": \"4\",\n      \"correctOption\": \"option4\",\n      \"difficulty\": \"easy\",\n      \"explanation\": \"2 + 2 = 4\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/questions/bulk",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "questions", "bulk"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "subject_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "topic_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "subtopic_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_id",
      "value": "",
      "type": "string"
    }
  ]
}
